{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.29/MicrosoftTeams.schema.json#",
  "manifestVersion": "1.29",
  "version": "1.1.0",
  "id": "495c91ee-b02c-4ae2-8ef8-c3aedf62dc87",
  "localizationInfo": {
    "defaultLanguageTag": "en-us"
  },
  "developer": {
    "name": "Vera",
    "websiteUrl": "https://localhost:3000/support",
    "privacyUrl": "https://localhost:3000/support",
    "termsOfUseUrl": "https://localhost:3000/support"
  },
  "name": {
    "short": "Vera Word Review M365",
    "full": "Vera Word Review for Microsoft 365"
  },
  "description": {
    "short": "Review selected Word text with a Vera Matter and lawyer-controlled changes.",
    "full": "Sign in to Vera through an Office dialog, review selected Word text with a Vera Matter, and keep tracked replacements and comments subject to lawyer review."
  },
  "icons": {
    "outline": "assets/vera-word-outline.png",
    "color": "assets/vera-word-color.png"
  },
  "accentColor": "#111827",
  "validDomains": [
    "localhost:3000"
  ],
  "showLoadingIndicator": false,
  "isFullScreen": false,
  "defaultBlockUntilAdminAction": false,
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "Document.ReadWrite.User",
          "type": "Delegated"
        }
      ]
    }
  },
  "extensions": [
    {
      "requirements": {
        "capabilities": [
          {
            "name": "WordApi",
            "minVersion": "1.3"
          }
        ],
        "scopes": [
          "document"
        ]
      },
      "runtimes": [
        {
          "requirements": {
            "capabilities": [
              {
                "name": "AddinCommands",
                "minVersion": "1.1"
              }
            ],
            "formFactors": [
              "desktop"
            ]
          },
          "id": "vera-word-taskpane-runtime",
          "type": "general",
          "code": {
            "page": "https://localhost:3000/office/word"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "VeraWordTaskpane",
              "type": "openPage",
              "displayName": "Open Vera Word Review",
              "pinnable": false,
              "view": "VeraWordTaskpane",
              "multiselect": false,
              "supportsNoItemContext": false
            }
          ]
        }
      ],
      "ribbons": [
        {
          "requirements": {
            "capabilities": [
              {
                "name": "AddinCommands",
                "minVersion": "1.1"
              }
            ],
            "scopes": [
              "document"
            ],
            "formFactors": [
              "desktop"
            ]
          },
          "contexts": [
            "default"
          ],
          "tabs": [
            {
              "builtInTabId": "TabHome",
              "groups": [
                {
                  "id": "Vera.Group.M365",
                  "label": "Vera",
                  "icons": [
                    {
                      "size": 16,
                      "url": "https://localhost:3000/office/vera-word-16.png"
                    },
                    {
                      "size": 32,
                      "url": "https://localhost:3000/office/vera-word-32.png"
                    },
                    {
                      "size": 80,
                      "url": "https://localhost:3000/office/vera-word-80.png"
                    }
                  ],
                  "controls": [
                    {
                      "id": "Vera.OpenTaskpane.M365",
                      "type": "button",
                      "label": "Review selected text",
                      "icons": [
                        {
                          "size": 16,
                          "url": "https://localhost:3000/office/vera-word-16.png"
                        },
                        {
                          "size": 32,
                          "url": "https://localhost:3000/office/vera-word-32.png"
                        },
                        {
                          "size": 80,
                          "url": "https://localhost:3000/office/vera-word-80.png"
                        }
                      ],
                      "supertip": {
                        "title": "Review selected text",
                        "description": "Open Vera to draft a reviewable tracked replacement or comment for the current Word selection."
                      },
                      "actionId": "VeraWordTaskpane",
                      "overriddenByRibbonApi": false,
                      "enabled": true
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "alternates": [
        {
          "hide": {
            "customOfficeAddin": {
              "officeAddinId": "6bf488ac-2916-4f3e-bdc0-8d7f66e7ab2e"
            }
          },
          "alternateIcons": {
            "icon": {
              "size": 32,
              "url": "https://localhost:3000/office/vera-word-32.png"
            },
            "highResolutionIcon": {
              "size": 80,
              "url": "https://localhost:3000/office/vera-word-80.png"
            }
          }
        }
      ],
      "getStartedMessages": [
        {
          "requirements": {
            "scopes": [
              "document"
            ],
            "formFactors": [
              "desktop"
            ]
          },
          "title": "Vera Word Review",
          "description": "Sign in to Vera, select Word text, and review any proposed change before applying it.",
          "learnMoreUrl": "https://localhost:3000/support"
        }
      ]
    }
  ]
}
